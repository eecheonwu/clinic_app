{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostClinicalRecordRequest",
  "type": "object",
  "properties": {
    "appointment_id": {
      "type": "string",
      "format": "uuid"
    },
    "patient_id": {
      "type": "string",
      "format": "uuid"
    },
    "notes": {
      "type": "string"
    },
    "diagnosis": {
      "type": "string"
    },
    "prescriptions": {
      "type": "string"
    }
  },
  "required": ["appointment_id", "patient_id", "notes", "diagnosis", "prescriptions"]
}
