# CMP Backend Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=Clinic Modernization Platform
APP_VERSION=1.0.0
ENVIRONMENT=dev  # dev, staging, production
DEBUG=True

# Database (AWS RDS PostgreSQL 16+)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://cmp_user:cmp_password@localhost:5432/cmp_db
DB_ECHO=False

# Redis (for Celery and rate limiting)
REDIS_URL=redis://localhost:6379/0

# AWS KMS Configuration
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
KMS_KEY_ID=arn:aws:kms:af-south-1:123456789012:key/12345678-1234-1234-1234-123456789012

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Configuration
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_REQUESTS=3
OTP_RATE_LIMIT_WINDOW_SECONDS=900

# Notification Providers
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=CMP-Clinic

INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_API_URL=https://api.infobip.com
INFOBIP_BASE_URL=https://api.infobip.com

# Notification Timeouts
NOTIFICATION_TIMEOUT_SECONDS=15
NOTIFICATION_MAX_RETRIES=3

# Transaction & Lock Timeouts
DB_TRANSACTION_TIMEOUT_SECONDS=3

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000